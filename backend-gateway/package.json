{
  "name": "@banking/backend-gateway",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run check:no-demo-attestation && npm run check:no-client-dek && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "check:no-client-dek": "node scripts/check-no-client-dek.mjs",
    "check:no-demo-attestation": "node scripts/check-no-demo-attestation.mjs",
    "migrate": "node scripts/migrate.mjs",
    "test:attestation-attacks": "node scripts/test-attestation-attacks.mjs"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "node-app-attest": "^1.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
